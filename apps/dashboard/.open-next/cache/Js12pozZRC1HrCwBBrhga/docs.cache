{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/page,_N_T_/docs"},"segmentPaths":["/_tree","/_full","/docs/__PAGE__","/docs","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"dark h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/07na3owrlyk6v.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0pvko7ddo.wlc.js\"/><script src=\"/_next/static/chunks/0b14u7_bsgsgw.js\" async=\"\"></script><script src=\"/_next/static/chunks/0gu8i76-a~w05.js\" async=\"\"></script><script src=\"/_next/static/chunks/0mb00ji-7pfuz.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-08uphm457z2i0.js\" async=\"\"></script><script src=\"/_next/static/chunks/03~kx7aoxxb.s.js\" async=\"\"></script><script src=\"/_next/static/chunks/06l48gn6t1t9z.js\" async=\"\"></script><script src=\"/_next/static/chunks/0dldrhnsy7qkc.js\" async=\"\"></script><link rel=\"preload\" href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap\" as=\"style\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><title>AgentBeam — AI Agent Observability</title><meta name=\"description\" content=\"Monitor, debug, and optimize your AI agents with real-time traces, cost analytics, and alerts.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap\" rel=\"stylesheet\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col font-sans\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen bg-[#09090b] text-white\"><nav class=\"sticky top-0 z-50 border-b border-white/[0.06] bg-[#09090b]/80 backdrop-blur-xl\"><div class=\"mx-auto flex h-14 max-w-6xl items-center justify-between px-4\"><a class=\"flex items-center gap-2 font-semibold tracking-tight\" href=\"/\"><div class=\"flex size-7 items-center justify-center rounded-md bg-gradient-to-br from-blue-500 to-blue-600\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-zap size-4 text-white\" aria-hidden=\"true\"><path d=\"M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z\"></path></svg></div>AgentBeam</a><div class=\"flex items-center gap-3\"><a class=\"rounded-md px-3 py-1.5 text-sm font-medium text-white\" href=\"/docs\">Docs</a><a class=\"rounded-md px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:text-white\" href=\"/login\">Sign In</a><a class=\"rounded-md bg-blue-600 px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-blue-500\" href=\"/signup\">Get Started</a></div></div></nav><div class=\"mx-auto flex max-w-6xl gap-8 px-4 py-12\"><aside class=\"hidden w-56 shrink-0 lg:block\"><div class=\"sticky top-24\"><a class=\"mb-6 flex items-center gap-1.5 text-sm text-zinc-500 transition-colors hover:text-white\" href=\"/\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-left size-3.5\" aria-hidden=\"true\"><path d=\"m12 19-7-7 7-7\"></path><path d=\"M19 12H5\"></path></svg>Back to home</a><p class=\"mb-3 text-xs font-semibold uppercase tracking-widest text-zinc-500\">On this page</p><nav class=\"flex flex-col gap-1\"><a href=\"#quickstart\" class=\"rounded-md px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-white/[0.04] hover:text-white\">Quickstart</a><a href=\"#installation\" class=\"rounded-md px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-white/[0.04] hover:text-white\">Installation</a><a href=\"#api-key\" class=\"rounded-md px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-white/[0.04] hover:text-white\">Get Your API Key</a><a href=\"#initialize\" class=\"rounded-md px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-white/[0.04] hover:text-white\">Initialize</a><a href=\"#manual-tracing\" class=\"rounded-md px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-white/[0.04] hover:text-white\">Manual Tracing</a><a href=\"#what-gets-captured\" class=\"rounded-md px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-white/[0.04] hover:text-white\">What Gets Captured</a><a href=\"#supported-providers\" class=\"rounded-md px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-white/[0.04] hover:text-white\">Supported Providers</a></nav></div></aside><main class=\"min-w-0 flex-1\"><section class=\"mb-16\"><div id=\"quickstart\" class=\"scroll-mt-24\"><div class=\"mb-4 flex items-center gap-3\"><div class=\"flex size-9 items-center justify-center rounded-lg bg-blue-500/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-book-open size-5 text-blue-400\" aria-hidden=\"true\"><path d=\"M12 7v14\"></path><path d=\"M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z\"></path></svg></div><h2 class=\"text-2xl font-bold tracking-tight\">Quickstart</h2></div></div><p class=\"text-lg text-zinc-400\">Start monitoring your AI agents in 60 seconds.</p></section><section class=\"mb-16\"><div id=\"installation\" class=\"scroll-mt-24\"><div class=\"mb-4 flex items-center gap-3\"><div class=\"flex size-9 items-center justify-center rounded-lg bg-blue-500/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-download size-5 text-blue-400\" aria-hidden=\"true\"><path d=\"M12 15V3\"></path><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"></path><path d=\"m7 10 5 5 5-5\"></path></svg></div><h2 class=\"text-2xl font-bold tracking-tight\">Installation</h2></div></div><p class=\"mb-6 text-sm text-zinc-400\">Install the SDK for your language of choice.</p><div class=\"flex flex-col gap-4\"><div><p class=\"mb-2 text-sm font-medium text-zinc-300\">Python</p><div class=\"overflow-hidden rounded-lg border border-white/[0.06] bg-[#0c0c0e]\"><div class=\"flex items-center gap-2 border-b border-white/[0.06] px-4 py-2\"><span class=\"text-xs font-medium text-zinc-500\">bash</span></div><pre class=\"overflow-x-auto p-4 font-mono text-sm leading-relaxed text-zinc-300\"><code>pip install git+https://github.com/agentbeamai-bot/agentbeam.git#subdirectory=packages/sdk-python</code></pre></div></div><div><p class=\"mb-2 text-sm font-medium text-zinc-300\">TypeScript / Node.js</p><div class=\"overflow-hidden rounded-lg border border-white/[0.06] bg-[#0c0c0e]\"><div class=\"flex items-center gap-2 border-b border-white/[0.06] px-4 py-2\"><span class=\"text-xs font-medium text-zinc-500\">bash</span></div><pre class=\"overflow-x-auto p-4 font-mono text-sm leading-relaxed text-zinc-300\"><code>npm install git+https://github.com/agentbeamai-bot/agentbeam.git#packages/sdk-node</code></pre></div></div></div></section><section class=\"mb-16\"><div id=\"api-key\" class=\"scroll-mt-24\"><div class=\"mb-4 flex items-center gap-3\"><div class=\"flex size-9 items-center justify-center rounded-lg bg-blue-500/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-key size-5 text-blue-400\" aria-hidden=\"true\"><path d=\"m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4\"></path><path d=\"m21 2-9.6 9.6\"></path><circle cx=\"7.5\" cy=\"15.5\" r=\"5.5\"></circle></svg></div><h2 class=\"text-2xl font-bold tracking-tight\">Get Your API Key</h2></div></div><ol class=\"flex flex-col gap-3 text-sm text-zinc-300\"><li class=\"flex items-start gap-3\"><span class=\"flex size-6 shrink-0 items-center justify-center rounded-full border border-blue-500/30 bg-blue-500/10 text-xs font-bold text-blue-400\">1</span><span>Sign up at<!-- --> <a href=\"https://agentbeam.agentbeamai.workers.dev/signup\" class=\"text-blue-400 underline underline-offset-2 hover:text-blue-300\">agentbeam.agentbeamai.workers.dev/signup</a></span></li><li class=\"flex items-start gap-3\"><span class=\"flex size-6 shrink-0 items-center justify-center rounded-full border border-blue-500/30 bg-blue-500/10 text-xs font-bold text-blue-400\">2</span><span>Go to <strong class=\"text-white\">Settings</strong> and click <strong class=\"text-white\">Generate New Key</strong></span></li><li class=\"flex items-start gap-3\"><span class=\"flex size-6 shrink-0 items-center justify-center rounded-full border border-blue-500/30 bg-blue-500/10 text-xs font-bold text-blue-400\">3</span><span>Copy the key immediately -- you will not be able to see it again</span></li></ol></section><section class=\"mb-16\"><div id=\"initialize\" class=\"scroll-mt-24\"><div class=\"mb-4 flex items-center gap-3\"><div class=\"flex size-9 items-center justify-center rounded-lg bg-blue-500/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-play size-5 text-blue-400\" aria-hidden=\"true\"><path d=\"M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z\"></path></svg></div><h2 class=\"text-2xl font-bold tracking-tight\">Initialize</h2></div></div><p class=\"mb-6 text-sm text-zinc-400\">Add a few lines of code to start tracing every LLM call automatically.</p><div class=\"flex flex-col gap-4\"><div><p class=\"mb-2 text-sm font-medium text-zinc-300\">Python</p><div class=\"overflow-hidden rounded-lg border border-white/[0.06] bg-[#0c0c0e]\"><div class=\"flex items-center gap-2 border-b border-white/[0.06] px-4 py-2\"><span class=\"text-xs font-medium text-zinc-500\">python</span></div><pre class=\"overflow-x-auto p-4 font-mono text-sm leading-relaxed text-zinc-300\"><code>import agentbeam\n\nagentbeam.init(\n    api_key=&quot;ab_your_key_here&quot;,\n    api_url=&quot;https://agentbeam.agentbeamai.workers.dev/api/v1&quot;,\n    agent_name=&quot;my-agent&quot;,\n)\n\n# That&#x27;s it! All Anthropic and OpenAI calls are now auto-traced.</code></pre></div></div><div><p class=\"mb-2 text-sm font-medium text-zinc-300\">TypeScript</p><div class=\"overflow-hidden rounded-lg border border-white/[0.06] bg-[#0c0c0e]\"><div class=\"flex items-center gap-2 border-b border-white/[0.06] px-4 py-2\"><span class=\"text-xs font-medium text-zinc-500\">typescript</span></div><pre class=\"overflow-x-auto p-4 font-mono text-sm leading-relaxed text-zinc-300\"><code>import { AgentBeam } from &#x27;agentbeam&#x27;;\n\nconst ab = new AgentBeam({\n  apiKey: &#x27;ab_your_key_here&#x27;,\n  apiUrl: &#x27;https://agentbeam.agentbeamai.workers.dev/api/v1&#x27;,\n  agentName: &#x27;my-agent&#x27;,\n});\n\nconst anthropic = ab.wrap(new Anthropic());\n// All calls through this client are now traced</code></pre></div></div></div></section><section class=\"mb-16\"><div id=\"manual-tracing\" class=\"scroll-mt-24\"><div class=\"mb-4 flex items-center gap-3\"><div class=\"flex size-9 items-center justify-center rounded-lg bg-blue-500/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-wrench size-5 text-blue-400\" aria-hidden=\"true\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z\"></path></svg></div><h2 class=\"text-2xl font-bold tracking-tight\">Manual Tracing (Optional)</h2></div></div><p class=\"mb-6 text-sm text-zinc-400\">Use decorators or context managers to trace custom logic beyond auto-instrumented LLM calls.</p><div><p class=\"mb-2 text-sm font-medium text-zinc-300\">Python</p><div class=\"overflow-hidden rounded-lg border border-white/[0.06] bg-[#0c0c0e]\"><div class=\"flex items-center gap-2 border-b border-white/[0.06] px-4 py-2\"><span class=\"text-xs font-medium text-zinc-500\">python</span></div><pre class=\"overflow-x-auto p-4 font-mono text-sm leading-relaxed text-zinc-300\"><code>from agentbeam.trace import trace, span\n\n@trace(name=&quot;process_order&quot;, kind=&quot;agent&quot;)\ndef process_order(order_id):\n    # Your logic here\n    return result\n\n# Or use context manager\nwith span(&quot;lookup_user&quot;, kind=&quot;tool&quot;):\n    user = db.get_user(user_id)</code></pre></div></div></section><section class=\"mb-16\"><div id=\"what-gets-captured\" class=\"scroll-mt-24\"><div class=\"mb-4 flex items-center gap-3\"><div class=\"flex size-9 items-center justify-center rounded-lg bg-blue-500/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-database size-5 text-blue-400\" aria-hidden=\"true\"><ellipse cx=\"12\" cy=\"5\" rx=\"9\" ry=\"3\"></ellipse><path d=\"M3 5V19A9 3 0 0 0 21 19V5\"></path><path d=\"M3 12A9 3 0 0 0 21 12\"></path></svg></div><h2 class=\"text-2xl font-bold tracking-tight\">What Gets Captured</h2></div></div><p class=\"mb-6 text-sm text-zinc-400\">Every traced call automatically records the following data.</p><div class=\"overflow-hidden rounded-lg border border-white/[0.06]\"><table class=\"w-full text-sm\"><thead><tr class=\"border-b border-white/[0.06] bg-white/[0.03]\"><th class=\"px-4 py-3 text-left font-semibold text-zinc-300\">Data</th><th class=\"px-4 py-3 text-left font-semibold text-zinc-300\">Example</th></tr></thead><tbody><tr class=\"border-b border-white/[0.04]\"><td class=\"px-4 py-3 text-zinc-300\">Model name &amp; provider</td><td class=\"px-4 py-3 font-mono text-xs text-zinc-500\">claude-3-opus / anthropic</td></tr><tr class=\"border-b border-white/[0.04]\"><td class=\"px-4 py-3 text-zinc-300\">Input / output token counts</td><td class=\"px-4 py-3 font-mono text-xs text-zinc-500\">1,204 in / 387 out</td></tr><tr class=\"border-b border-white/[0.04]\"><td class=\"px-4 py-3 text-zinc-300\">Cost (calculated automatically)</td><td class=\"px-4 py-3 font-mono text-xs text-zinc-500\">$0.0234</td></tr><tr class=\"border-b border-white/[0.04]\"><td class=\"px-4 py-3 text-zinc-300\">Latency &amp; time-to-first-token</td><td class=\"px-4 py-3 font-mono text-xs text-zinc-500\">1.2s / 320ms</td></tr><tr class=\"border-b border-white/[0.04]\"><td class=\"px-4 py-3 text-zinc-300\">Tool / function calls</td><td class=\"px-4 py-3 font-mono text-xs text-zinc-500\">get_weather, search_db</td></tr><tr class=\"border-b border-white/[0.04]\"><td class=\"px-4 py-3 text-zinc-300\">Error messages &amp; stack traces</td><td class=\"px-4 py-3 font-mono text-xs text-zinc-500\">RateLimitError at line 42</td></tr><tr class=\"\"><td class=\"px-4 py-3 text-zinc-300\">Custom metadata</td><td class=\"px-4 py-3 font-mono text-xs text-zinc-500\">user_id, session_id, tags</td></tr></tbody></table></div></section><section class=\"mb-16\"><div id=\"supported-providers\" class=\"scroll-mt-24\"><div class=\"mb-4 flex items-center gap-3\"><div class=\"flex size-9 items-center justify-center rounded-lg bg-blue-500/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-cpu size-5 text-blue-400\" aria-hidden=\"true\"><path d=\"M12 20v2\"></path><path d=\"M12 2v2\"></path><path d=\"M17 20v2\"></path><path d=\"M17 2v2\"></path><path d=\"M2 12h2\"></path><path d=\"M2 17h2\"></path><path d=\"M2 7h2\"></path><path d=\"M20 12h2\"></path><path d=\"M20 17h2\"></path><path d=\"M20 7h2\"></path><path d=\"M7 20v2\"></path><path d=\"M7 2v2\"></path><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"2\"></rect><rect x=\"8\" y=\"8\" width=\"8\" height=\"8\" rx=\"1\"></rect></svg></div><h2 class=\"text-2xl font-bold tracking-tight\">Supported Providers</h2></div></div><div class=\"grid gap-3 sm:grid-cols-2\"><div class=\"flex items-center justify-between rounded-lg border border-white/[0.06] bg-white/[0.03] px-4 py-3\"><span class=\"text-sm font-medium text-zinc-200\">Anthropic (Claude)</span><span class=\"rounded-full px-2.5 py-0.5 text-xs font-medium bg-emerald-500/10 text-emerald-400\">Auto-instrumented</span></div><div class=\"flex items-center justify-between rounded-lg border border-white/[0.06] bg-white/[0.03] px-4 py-3\"><span class=\"text-sm font-medium text-zinc-200\">OpenAI (GPT)</span><span class=\"rounded-full px-2.5 py-0.5 text-xs font-medium bg-emerald-500/10 text-emerald-400\">Auto-instrumented</span></div><div class=\"flex items-center justify-between rounded-lg border border-white/[0.06] bg-white/[0.03] px-4 py-3\"><span class=\"text-sm fon