{
  "name": "agentbeam",
  "version": "0.2.0",
  "description": "Monitor, debug, and manage the cost of AI agents in production",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "require": "./dist/auto.js",
      "import": "./dist/auto.js",
      "default": "./dist/auto.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "monitoring",
    "observability",
    "llm",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "peerDependencies": {
    "anthropic": ">=0.20.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "anthropic": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
